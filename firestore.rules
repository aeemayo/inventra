rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isShopMember(shopId) {
      return isAuthenticated() && getUserData().shopId == shopId;
    }

    function isShopAdmin(shopId) {
      return isShopMember(shopId) && getUserData().role == 'admin';
    }

    function isShopAdminOrManager(shopId) {
      return isShopMember(shopId) && (getUserData().role == 'admin' || getUserData().role == 'manager');
    }

    // ── Field validation helpers ──
    function hasRequiredProductFields() {
      return request.resource.data.keys().hasAll([
        'name', 'sku', 'costPrice', 'sellingPrice', 'quantity',
        'reorderLevel', 'isActive', 'createdAt', 'updatedAt',
        'createdBy', 'updatedBy'
      ]);
    }

    function hasRequiredTransactionFields() {
      return request.resource.data.keys().hasAll([
        'type', 'items', 'subtotal', 'total', 'paymentMethod',
        'status', 'createdBy', 'createdByName', 'createdAt'
      ]);
    }

    // ── Users Collection ──
    match /users/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create: if isAuthenticated() && isOwner(userId)
                    && request.resource.data.keys().hasAll(['email', 'displayName', 'role', 'createdAt', 'updatedAt'])
                    && request.resource.data.role in ['admin', 'manager', 'warehouse', 'sales'];
      allow update: if isAuthenticated() && isOwner(userId)
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'createdAt']);
      allow delete: if false; // Users cannot be deleted from client
    }

    // ── Shops Collection ──
    match /shops/{shopId} {
      allow read: if isShopMember(shopId);
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAll(['name', 'ownerId', 'isActive', 'createdAt', 'updatedAt'])
                    && request.resource.data.ownerId == request.auth.uid;
      allow update: if isShopAdmin(shopId)
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerId', 'createdAt']);
      allow delete: if false;

      // ── Products ──
      match /products/{productId} {
        allow read: if isShopMember(shopId);
        allow create: if isShopMember(shopId)
                      && getUserData().role in ['admin', 'manager', 'warehouse']
                      && hasRequiredProductFields()
                      && request.resource.data.quantity >= 0;
        allow update: if isShopMember(shopId)
                      && getUserData().role in ['admin', 'manager', 'warehouse']
                      && request.resource.data.quantity >= 0;
        allow delete: if isShopAdminOrManager(shopId);
      }

      // ── Categories ──
      match /categories/{categoryId} {
        allow read: if isShopMember(shopId);
        allow create, update: if isShopAdminOrManager(shopId)
                              && request.resource.data.keys().hasAll(['name']);
        allow delete: if isShopAdmin(shopId);
      }

      // ── Transactions ──
      match /transactions/{transactionId} {
        allow read: if isShopMember(shopId);
        allow create: if isShopMember(shopId)
                      && hasRequiredTransactionFields()
                      && request.resource.data.type in ['sale', 'refund']
                      && request.resource.data.status in ['completed', 'pending', 'cancelled'];
        allow update: if isShopAdminOrManager(shopId)
                      && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdBy', 'createdAt', 'items']);
        allow delete: if false; // Transactions are immutable
      }

      // ── Stock Movements ──
      match /stock_movements/{movementId} {
        allow read: if isShopMember(shopId);
        allow create: if isShopMember(shopId)
                      && request.resource.data.keys().hasAll([
                        'productId', 'productName', 'type', 'quantityChange',
                        'quantityBefore', 'quantityAfter', 'userId', 'userName', 'source', 'createdAt'
                      ])
                      && request.resource.data.type in ['sale', 'restock', 'adjustment', 'return'];
        allow update, delete: if false; // Audit trail: immutable
      }

      // ── Scan History ──
      match /scan_history/{scanId} {
        allow read: if isShopMember(shopId);
        allow create: if isShopMember(shopId)
                      && request.resource.data.keys().hasAll(['barcodeValue', 'status', 'scanIntent', 'scannedBy']);
        allow update, delete: if false;
      }

      // ── Notifications ──
      match /notifications/{notificationId} {
        allow read: if isShopMember(shopId);
        allow create: if isShopAdminOrManager(shopId)
                      && request.resource.data.keys().hasAll(['type', 'title', 'body', 'read', 'createdAt']);
        allow update: if isShopMember(shopId)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow delete: if isShopAdmin(shopId);
      }

      // ── Analytics Snapshots ──
      match /analytics_snapshots/{snapshotId} {
        allow read: if isShopMember(shopId) && getUserData().role in ['admin', 'manager'];
        allow write: if false; // Written by Cloud Functions only
      }

      // ── Settings ──
      match /settings/{docId} {
        allow read: if isShopMember(shopId);
        allow write: if isShopAdmin(shopId);
      }
    }
  }
}
